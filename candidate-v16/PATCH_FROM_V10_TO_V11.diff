+async function configLint() {
+  const config = await sanitizedConfigStatus();
+  const repos = Array.isArray(config.repos?.repos) ? config.repos.repos : [];
+  const keys = Array.isArray(config.keys?.keys) ? config.keys.keys : [];
+  const routes = await readJson(ROUTES_FILE, { profiles: [] });
+  const profiles = Array.isArray(routes.profiles) ? routes.profiles : [];
+  const warnings = [];
+  const errors = [];
+  const repoAliases = new Map();
+  for (const repo of repos) {
+    const alias = safeId(repo.repo_alias || repo.alias || '', '');
+    if (!alias) errors.push({ code: 'repo_alias_missing', repo });
+    if (alias && repoAliases.has(alias)) errors.push({ code: 'repo_alias_duplicate', alias });
+    if (alias) repoAliases.set(alias, repo);
+    const branch = String(repo.branch || '').toLowerCase();
+    if (!repo.dry_run && ['main', 'master', 'production', 'release'].includes(branch)) warnings.push({ code: 'repo_branch_high_impact', alias, branch, recommendation: 'use a dedicated archive branch unless owner approves this repo_alias for real use' });
+    if (!repo.owner || !repo.repo) errors.push({ code: 'repo_target_incomplete', alias });
+  }
+  const keyAliases = new Map();
+  for (const key of keys) {
+    const alias = safeId(key.key_alias || key.alias || '', '');
+    if (!alias) errors.push({ code: 'key_alias_missing', key: { provider: key.provider || '' } });
+    if (alias && keyAliases.has(alias)) errors.push({ code: 'key_alias_duplicate', alias });
+    if (alias) keyAliases.set(alias, key);
+    if (!key.token_env && !key.token_file && !key.dry_run) warnings.push({ code: 'key_material_unresolved', alias, recommendation: 'provide token_env or token_file in the local bridge environment' });
+  }
+  for (const profile of profiles) {
+    const profileId = safeId(profile.route_profile || profile.routeProfile || profile.id || '', '');
+    const repoAlias = safeId(profile.repo_alias || profile.repoAlias || '', '');
+    const keyAlias = safeId(profile.key_alias || profile.keyAlias || '', '');
+    if (repoAlias && !repoAliases.has(repoAlias)) errors.push({ code: 'route_repo_alias_missing', profile: profileId, repo_alias: repoAlias });
+    if (keyAlias && !keyAliases.has(keyAlias)) errors.push({ code: 'route_key_alias_missing', profile: profileId, key_alias: keyAlias });
