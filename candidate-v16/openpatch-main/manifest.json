{
  "manifest_version": 3,
  "name": "OpenPatch",
  "version": "0.2.0",
  "description": "Agent-friendly ChatGPT artifact uploader with patch upload and archive-only RoundPack gateway modes.",
  "permissions": [
    "downloads",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://*.openai.com/*",
    "https://*.oaiusercontent.com/*",
    "https://oaiusercontent.com/*",
    "http://127.0.0.1:*/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "pages/popup.html",
    "default_title": "OpenPatch"
  },
  "options_page": "pages/options.html",
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "src/page-bridge.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "src/content-script.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
