{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openpatch.auto_continue_plan.v1.schema.json",
  "type": "object",
  "required": ["ok", "schema_version", "project", "should_request_roundpack", "next_agent_action"],
  "properties": {
    "ok": { "type": "boolean" },
    "schema_version": { "const": "openpatch.auto_continue_plan.v1" },
    "project": { "type": "string" },
    "should_request_roundpack": { "type": "boolean" },
    "should_pause_until_archive_receipt": { "type": "boolean" },
    "reason": { "type": "string" },
    "required_marker": { "type": "string" },
    "preferred_file_name": { "type": "string" },
    "prompt_hint": { "type": "string" },
    "next_agent_action": { "type": "string" },
    "created_at": { "type": "string" }
  },
  "additionalProperties": true
}
